{
  "id": "poster_abstract",
  "label": "Conference Poster Abstract",
  "description": "Structured abstract for conference poster submission. Sections: Introduction, Methods, Results, Conclusions. Total ~400 words. No citations pass, no cohesion, no PLS.",

  "pre_pipeline": {
    "extractions": ["bp_chunks", "ko_guides"],
    "note": "Run once at project setup. Same extraction as primary_research."
  },

  "context_availability": {
    "source_materials": ["methods", "results", "introduction"],
    "literature":        ["introduction"]
  },

  "nodes": [
    {
      "section_type": "methods",
      "label": "Methods",
      "skill": "methods",
      "deps": [],
      "multi_section": false,
      "context": {
        "source_materials": true,
        "literature": false,
        "upstream_sections": []
      },
      "word_count": { "min": 80, "max": 100 },
      "execution_paths": null,
      "gate": null,
      "review": null,
      "enabled": true
    },

    {
      "section_type": "results",
      "label": "Results",
      "skill": "results",
      "deps": ["methods"],
      "multi_section": false,
      "context": {
        "source_materials": true,
        "literature": false,
        "upstream_sections": []
      },
      "word_count": { "min": 150, "max": 200 },
      "execution_paths": null,
      "gate": null,
      "review": null,
      "enabled": true
    },

    {
      "section_type": "introduction",
      "label": "Introduction / Background",
      "skill": "introduction",
      "deps": ["methods", "results"],
      "multi_section": true,
      "context": {
        "source_materials": true,
        "literature": true,
        "upstream_sections": ["methods", "results"],
        "note": "Reads Methods and Results so the framing matches exactly what was found."
      },
      "word_count": { "min": 80, "max": 100 },
      "execution_paths": null,
      "gate": null,
      "review": null,
      "enabled": true
    },

    {
      "section_type": "conclusion",
      "label": "Conclusions",
      "skill": "conclusion",
      "deps": ["methods", "results"],
      "multi_section": true,
      "context": {
        "source_materials": false,
        "literature": false,
        "upstream_sections": ["methods", "results"],
        "note": "Methods and Results only — same clinical guardrail as primary_research."
      },
      "word_count": { "min": 60, "max": 80 },
      "execution_paths": null,
      "gate": null,
      "review": null,
      "enabled": true
    },

    {
      "section_type": "assembly",
      "label": "Final Assembly",
      "skill": null,
      "deps": ["introduction", "methods", "results", "conclusion"],
      "multi_section": false,
      "context": {
        "upstream_sections": ["introduction", "methods", "results", "conclusion"]
      },
      "word_count": null,
      "execution_paths": null,
      "gate": null,
      "review": null,
      "enabled": true
    }
  ],

  "outputs": ["docx", "pdf"]
}
